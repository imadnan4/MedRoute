# MedRoute Configuration — Copy to backend/.env and fill in your values

# ----- AMD Developer Cloud — Nemotron 3.5 ASR (voice transcription) -----
# Runs Nemotron 3.5 ASR 0.6B via NVIDIA NeMo on AMD GPU
# The backend POSTs audio here: {ASR_SERVER_URL}/transcribe
MEDROUTE_ASR_SERVER_URL=http://YOUR_AMD_CLOUD_IP:8080

# ----- AMD Developer Cloud — Ollama (Hippo-Mistral-7B for local LLM) -----
MEDROUTE_OLLAMA_BASE_URL=http://YOUR_AMD_CLOUD_IP:11434

# ----- Fireworks AI — DeepSeek V4 (remote LLM for complex cases) -----
MEDROUTE_FIREWORKS_API_KEY=

# ----- WHO ICD-11 API (free token from https://id.who.int/) -----
MEDROUTE_ICD_API_KEY=

# ----- HuggingFace (optional, for faster model downloads) -----
MEDROUTE_HF_TOKEN=

# ----- Server -----
MEDROUTE_HOST=0.0.0.0
MEDROUTE_PORT=8000
